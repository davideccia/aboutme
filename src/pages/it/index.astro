---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card/index.astro";
import IntroCard from "../../components/it/IntroCard.astro";
import ContactsCard from "../../components/it/ContactsCard.astro";
import TimeZone from "../../components/it/TimeZoneCard.astro";
import AboutMe from "../../components/it/AboutMe.astro";
import Now from "../../components/it/Now.astro";
import Globe from "../../components/Globe";
import { getRelativeLocaleUrl } from "astro:i18n";
const indexURL = getRelativeLocaleUrl("en", "");
---

<script>
  import { stagger, spring, timeline, type TimelineDefinition } from "motion";
  import { loaderAnimation } from "../../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        at: "-0.1",
        duration: 0.4,
        delay: stagger(0.3),
        easing: spring({ velocity: 100, stiffness: 50, damping: 10 }),
      },
    ],
  ];

  timeline(sequence as TimelineDefinition);
</script>

<Layout
  title="Davide Ciaccia - Backend Developer"
  description="I'm a developer based in Italy, passionate about user experience and specializing in engaging animations and micro-interactions. My primary tools of choice include: JavaScript, React, Solid.js, Astro, Svelte, and Node.js."
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <IntroCard />
    <AboutMe />
    <Card
      colSpan="md:col-span-1"
      rowSpan="md:row-span-1"
      title="I miei viaggi"
      href="travel"
      colorText="text-neutral-900"
    >
      <div class="h-full w-full absolute inset-0 -z-10">
        <Globe client:load />
      </div>
    </Card>
    <TimeZone />
    <Now />
    <Card colSpan="md:col-span-2" rowSpan="md:row-span-1">
      <p class="text-xs">
        Un grazie speciale a <a
          href="https://github.com/Ladvace/astro-bento-portfolio"
          target="_blank"
          class="text-primary-100"
        >
          Gianmarco</a
        > per questo template
        <br />
        © 2024-Adesso · Creato con il ♥️ utilizzando <a
          href="https://astro.build/"
          target="_blank"
          class="text-primary-100">Astro</a
        >.
      </p>
    </Card>
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1" href={indexURL}>
      🌍 English content
    </Card>
    <Card colSpan="md:col-span-4" rowSpan="md:row-span-1">
      <p style="text-align: center;">
        contattami: <a
          class="text-primary-100"
          target="_blank"
          href="mailto:davideccia@gmail.com">davideccia@gmail.com</a
        >
      </p>
    </Card>
  </main>
</Layout>
