---
import Globe from "../../components/Globe";
import BasicLayout from "../../layouts/BasicLayout.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
const indexURL = getRelativeLocaleUrl("it", "");
---

<script>
  import { timeline, type TimelineDefinition } from "motion";

  const sequence = [
    [
      ".loaderRef",
      { opacity: [1, 0], pointerEvents: "none" },
      { easing: "ease-out" },
    ],
  ];

  timeline(sequence as TimelineDefinition);
</script>

<BasicLayout
  title="Davide Ciaccia - Nazioni Visitate"
  description="Globo 3D"
  page="travel"
>
  <a
    href={indexURL}
    class="text-white absolute bg-neutral-900 hover:bg-neutral-800 top-4 left-4 px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg"
    >Torna indietro</a
  >

  <Globe client:load />
</BasicLayout>
